# ═══════════════════════════════════════════════════════════════
#  Bounties & Berries – Frontend Environment Variables
#  Copy to .env.development and .env.production and fill values.
#  Expo only exposes EXPO_PUBLIC_* vars to the client bundle.
# ═══════════════════════════════════════════════════════════════

# ─── API ───────────────────────────────────────────────────────
# Dev (Android emulator): http://10.0.2.2:3001
# Dev (iOS sim / web):    http://localhost:3001
# Production:             https://api.yourapp.com
EXPO_PUBLIC_API_URL=http://localhost:3001

# ─── Environment tag ───────────────────────────────────────────
EXPO_PUBLIC_ENV=development     # development | staging | production

# ─── Error Monitoring (optional) ──────────────────────────────
# EXPO_PUBLIC_SENTRY_DSN=https://xxxx@yyy.ingest.sentry.io/zzz
